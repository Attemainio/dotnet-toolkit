{
  "description": "Keeps C# edits on the validate_patch write path, keeps C# reads on search_index/get_symbol (including via Bash), and reminds Claude to refresh the workspace after creating a new .cs file",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/guard-cs-edit.sh",
            "timeout": 10,
            "statusMessage": "Checking C# write path..."
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/guard-cs-read.sh",
            "timeout": 10,
            "statusMessage": "Checking C# read path..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/guard-cs-bash-read.sh",
            "timeout": 10,
            "statusMessage": "Checking Bash command for a raw C# read..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/hint-reload-new-cs-file.sh",
            "timeout": 10,
            "statusMessage": "Checking whether the workspace needs a reload..."
          }
        ]
      }
    ]
  }
}
